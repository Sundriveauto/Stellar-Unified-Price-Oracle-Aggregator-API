# ── PostgreSQL ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://oracle:oracle@localhost:5432/oracle
POSTGRES_USER=oracle
POSTGRES_PASSWORD=oracle
POSTGRES_DB=oracle

# ── Stellar / Soroban ──────────────────────────────────────────────────────
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
CONTRACT_ID=

# Aggregator signing key (Stellar secret key, S...)
AGGREGATOR_SECRET_KEY=

# ── Aggregator ─────────────────────────────────────────────────────────────
POLL_INTERVAL=60000
ASSET_PAIRS=XLM/USD,BTC/USD,ETH/USD,USDC/USD,SOL/USD

# Retry config for price sources
SOURCE_MAX_RETRIES=3
SOURCE_RETRY_DELAY_MS=1000

# ── API ────────────────────────────────────────────────────────────────────
PORT=3000

# API key for authentication (leave empty to disable auth in dev)
API_KEY=

# CORS allowed origin (* = all)
CORS_ORIGIN=*

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# WebSocket broadcast interval in milliseconds
WS_BROADCAST_INTERVAL=5000

# ── Staleness ──────────────────────────────────────────────────────────────
# Prices older than this (ms) are marked stale (default: 5 min)
STALE_THRESHOLD_MS=300000

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Oracle Sources ─────────────────────────────────────────────────────────
REFLECTOR_API_URL=https://data.reflector.network/api/v1
